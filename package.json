{
  "name": "tachiyomi-compression-service",
  "version": "7.0.0",
  "description": "Servicio de compresión de imágenes optimizado para HF Spaces - Sin límites de tiempo, máximo rendimiento",
  "main": "api/server.js",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "sharp": "^0.33.4",
    "express": "^4.19.2"
  },
  "scripts": {
    "start": "node --max-old-space-size=8192 --optimize-for-size --memory-reducer --max-semi-space-size=128 --optimize-for-size api/server.js",
    "dev": "node --max-old-space-size=6144 api/server.js",
    "test": "node --check api/server.js && node --check api/compress.js"
  },
  "keywords": [
    "image-compression",
    "tachiyomi",
    "hf-spaces",
    "sharp",
    "nodejs"
  ],
  "author": "ADONAIFV",
  "license": "MIT"
}

